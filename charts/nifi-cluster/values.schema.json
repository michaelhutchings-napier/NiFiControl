{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "image",
    "replicas",
    "service",
    "storage",
    "resources",
    "jvm",
    "scheduling",
    "podDisruptionBudget",
    "ingress",
    "upgrade",
    "scaleDown",
    "coordination",
    "api",
    "internalTLS",
    "metrics",
    "additionalEnv",
    "deletionPolicy",
    "driftPolicy"
  ],
  "properties": {
    "nameOverride": {
      "type": "string"
    },
    "fullnameOverride": {
      "type": "string"
    },
    "image": {
      "type": "object",
      "required": [
        "repository",
        "tag",
        "pullPolicy"
      ],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string",
          "minLength": 1
        },
        "pullPolicy": {
          "type": "string",
          "enum": [
            "Always",
            "IfNotPresent",
            "Never"
          ]
        }
      }
    },
    "replicas": {
      "type": "integer",
      "minimum": 1
    },
    "maxTimerDrivenThreadCount": {
      "type": "integer",
      "minimum": 0,
      "maximum": 1000
    },
    "service": {
      "type": "object",
      "required": [
        "type",
        "port",
        "nodePort",
        "annotations"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "ClusterIP",
            "NodePort",
            "LoadBalancer"
          ]
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "nodePort": {
          "type": "integer",
          "minimum": 0,
          "maximum": 65535
        },
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "ports": {
      "type": "object",
      "properties": {
        "http": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "clusterProtocol": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "remoteInput": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "loadBalance": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      },
      "additionalProperties": false
    },
    "externalServices": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "ports"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 63
          },
          "type": {
            "type": "string",
            "enum": [
              "ClusterIP",
              "NodePort",
              "LoadBalancer"
            ]
          },
          "ports": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "name",
                "port"
              ],
              "properties": {
                "name": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 15
                },
                "port": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 65535
                },
                "targetPort": {
                  "type": "string"
                },
                "nodePort": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 65535
                },
                "protocol": {
                  "type": "string",
                  "enum": [
                    "TCP",
                    "UDP",
                    "SCTP"
                  ]
                }
              },
              "additionalProperties": false
            }
          },
          "annotations": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "labels": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "loadBalancerIP": {
            "type": "string"
          },
          "loadBalancerSourceRanges": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "externalTrafficPolicy": {
            "type": "string",
            "enum": [
              "Cluster",
              "Local"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "additionalProxyHosts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 253
      }
    },
    "clusterDomain": {
      "type": "string",
      "maxLength": 253
    },
    "storage": {
      "type": "object",
      "required": [
        "enabled",
        "size",
        "accessModes"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "size": {
          "type": "string",
          "minLength": 1
        },
        "storageClassName": {
          "type": "string"
        },
        "accessModes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "repositories": {
          "type": "object",
          "description": "Dedicated PersistentVolumes for individual NiFi repositories; unset repositories stay on the main data volume.",
          "properties": {
            "flowfile": {
              "type": "object",
              "properties": {
                "size": {
                  "type": [
                    "string",
                    "number"
                  ]
                },
                "storageClassName": {
                  "type": "string"
                },
                "accessModes": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "additionalProperties": false
            },
            "content": {
              "type": "object",
              "properties": {
                "size": {
                  "type": [
                    "string",
                    "number"
                  ]
                },
                "storageClassName": {
                  "type": "string"
                },
                "accessModes": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "additionalProperties": false
            },
            "provenance": {
              "type": "object",
              "properties": {
                "size": {
                  "type": [
                    "string",
                    "number"
                  ]
                },
                "storageClassName": {
                  "type": "string"
                },
                "accessModes": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "additionalProperties": false
            },
            "database": {
              "type": "object",
              "properties": {
                "size": {
                  "type": [
                    "string",
                    "number"
                  ]
                },
                "storageClassName": {
                  "type": "string"
                },
                "accessModes": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      }
    },
    "resources": {
      "type": "object"
    },
    "jvm": {
      "type": "object",
      "required": [
        "heapInitial",
        "heapMax"
      ],
      "properties": {
        "heapInitial": {
          "type": "string",
          "minLength": 1
        },
        "heapMax": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "scheduling": {
      "type": "object",
      "required": [
        "nodeSelector",
        "tolerations",
        "affinity",
        "topologySpreadConstraints",
        "priorityClassName"
      ],
      "properties": {
        "nodeSelector": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "tolerations": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "affinity": {
          "type": "object"
        },
        "topologySpreadConstraints": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "priorityClassName": {
          "type": "string"
        },
        "oneNifiNodePerNode": {
          "type": "boolean"
        }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "required": [
        "enabled"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "maxUnavailable": {
          "$ref": "#/definitions/intOrStringOrNull"
        },
        "minAvailable": {
          "$ref": "#/definitions/intOrStringOrNull"
        }
      }
    },
    "ingress": {
      "type": "object",
      "required": [
        "enabled",
        "ingressClassName",
        "host",
        "path",
        "pathType",
        "contextPath",
        "annotations",
        "tls"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "ingressClassName": {
          "type": "string"
        },
        "host": {
          "type": "string"
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "pathType": {
          "type": "string",
          "enum": [
            "Exact",
            "Prefix",
            "ImplementationSpecific"
          ]
        },
        "contextPath": {
          "type": "string"
        },
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "tls": {
          "type": "object",
          "required": [
            "secretName",
            "hosts"
          ],
          "properties": {
            "secretName": {
              "type": "string"
            },
            "hosts": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "upgrade": {
      "type": "object",
      "required": [
        "strategy",
        "minReadySeconds"
      ],
      "properties": {
        "strategy": {
          "type": "string",
          "enum": [
            "RollingUpdate",
            "OnDelete"
          ]
        },
        "partition": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "minReadySeconds": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "scaleDown": {
      "type": "object",
      "required": [
        "offloadData",
        "timeoutSeconds",
        "onTimeout"
      ],
      "properties": {
        "offloadData": {
          "type": "boolean"
        },
        "timeoutSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "onTimeout": {
          "type": "string",
          "enum": [
            "Fail",
            "Force"
          ]
        }
      }
    },
    "coordination": {
      "type": "object",
      "required": [
        "zookeeperConnectString",
        "zookeeperRootNode",
        "electionMaxWait"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["ZooKeeper", "Kubernetes"]
        },
        "zookeeperConnectString": {
          "type": "string"
        },
        "zookeeperRootNode": {
          "type": "string"
        },
        "electionMaxWait": {
          "type": "string"
        },
        "leasePrefix": {
          "type": "string"
        }
      }
    },
    "api": {
      "type": "object",
      "required": [
        "uri",
        "timeout"
      ],
      "properties": {
        "uri": {
          "type": "string"
        },
        "timeout": {
          "type": "string"
        }
      }
    },
    "internalTLS": {
      "type": "object",
      "required": [
        "enabled",
        "httpsPort",
        "selfSigned",
        "issuerRef",
        "external",
        "certificate"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "httpsPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "selfSigned": {
          "type": "object",
          "required": [
            "caCommonName",
            "caDuration"
          ],
          "properties": {
            "caCommonName": {
              "type": "string"
            },
            "caDuration": {
              "type": "string"
            }
          }
        },
        "issuerRef": {
          "type": "object",
          "required": [
            "name",
            "kind",
            "group"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "kind": {
              "type": "string",
              "enum": [
                "Issuer",
                "ClusterIssuer"
              ]
            },
            "group": {
              "type": "string"
            }
          }
        },
        "external": {
          "type": "object",
          "required": [
            "serverSecretName",
            "clientSecretName",
            "keystorePasswordSecretRef",
            "initialAdminIdentity",
            "nodeIdentity"
          ],
          "properties": {
            "serverSecretName": {
              "type": "string"
            },
            "clientSecretName": {
              "type": "string"
            },
            "keystorePasswordSecretRef": {
              "type": "object",
              "required": [
                "name",
                "key"
              ],
              "properties": {
                "name": {
                  "type": "string"
                },
                "key": {
                  "type": "string",
                  "minLength": 1
                }
              }
            },
            "initialAdminIdentity": {
              "type": "string"
            },
            "nodeIdentity": {
              "type": "string"
            }
          }
        },
        "certificate": {
          "type": "object",
          "required": [
            "duration",
            "renewBefore",
            "additionalServerSANs",
            "operatorCommonName",
            "nodeCommonName"
          ],
          "properties": {
            "duration": {
              "type": "string"
            },
            "renewBefore": {
              "type": "string"
            },
            "additionalServerSANs": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "operatorCommonName": {
              "type": "string"
            },
            "nodeCommonName": {
              "type": "string"
            }
          }
        }
      }
    },
    "metrics": {
      "type": "object",
      "required": [
        "enabled",
        "path",
        "serviceMonitor"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "path": {
          "type": "string"
        },
        "serviceMonitor": {
          "type": "object",
          "required": [
            "enabled",
            "interval",
            "scrapeTimeout",
            "labels",
            "insecureSkipVerify"
          ],
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "interval": {
              "type": "string"
            },
            "scrapeTimeout": {
              "type": "string"
            },
            "labels": {
              "type": "object",
              "additionalProperties": {
                "type": "string"
              }
            },
            "insecureSkipVerify": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "additionalEnv": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "configOverrides": {
      "type": "object",
      "description": "Raw configuration entries merged into nifi.properties / bootstrap.conf after the operator-managed settings; an override wins and removal restores the image default.",
      "properties": {
        "nifiProperties": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "nifiPropertiesFrom": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            },
            "required": [
              "name"
            ],
            "additionalProperties": false
          }
        },
        "bootstrapProperties": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "logbackXml": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "pod": {
      "type": "object",
      "description": "Customize the generated NiFi node pods: extra metadata, image pull secrets, ServiceAccount, sidecars, init containers, and additional volumes/mounts.",
      "properties": {
        "labels": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "imagePullSecrets": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "serviceAccountName": {
          "type": "string"
        },
        "securityContext": {
          "type": "object"
        },
        "containerSecurityContext": {
          "type": "object"
        },
        "terminationGracePeriodSeconds": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "probes": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "startup": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "initialDelaySeconds": { "type": "integer", "minimum": 0 },
                "periodSeconds": { "type": "integer", "minimum": 1 },
                "timeoutSeconds": { "type": "integer", "minimum": 1 },
                "failureThreshold": { "type": "integer", "minimum": 1 },
                "successThreshold": { "type": "integer", "minimum": 1 }
              }
            },
            "liveness": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "initialDelaySeconds": { "type": "integer", "minimum": 0 },
                "periodSeconds": { "type": "integer", "minimum": 1 },
                "timeoutSeconds": { "type": "integer", "minimum": 1 },
                "failureThreshold": { "type": "integer", "minimum": 1 },
                "successThreshold": { "type": "integer", "minimum": 1 }
              }
            },
            "readiness": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "initialDelaySeconds": { "type": "integer", "minimum": 0 },
                "periodSeconds": { "type": "integer", "minimum": 1 },
                "timeoutSeconds": { "type": "integer", "minimum": 1 },
                "failureThreshold": { "type": "integer", "minimum": 1 },
                "successThreshold": { "type": "integer", "minimum": 1 }
              }
            }
          }
        },
        "hostAliases": {
          "type": "array",
          "items": { "type": "object" }
        },
        "dnsPolicy": {
          "type": ["string", "null"],
          "enum": ["ClusterFirst", "ClusterFirstWithHostNet", "Default", "None", null]
        },
        "dnsConfig": {
          "type": "object"
        },
        "extraVolumes": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "extraVolumeMounts": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "extraInitContainers": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "extraContainers": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      },
      "additionalProperties": false
    },
    "deletionPolicy": {
      "type": "string",
      "enum": [
        "Delete",
        "Orphan"
      ]
    },
    "driftPolicy": {
      "type": "object",
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "Ignore",
            "Warn",
            "Reconcile",
            "Fail"
          ]
        }
      }
    },
    "authentication": {
      "type": "object",
      "description": "User authentication for a secured cluster (requires internalTLS). Mode SingleUser, LDAP, or OIDC; adminIdentities get the administrative policy set.",
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "",
            "SingleUser",
            "LDAP",
            "OIDC"
          ]
        },
        "adminIdentities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "singleUser": {
          "type": "object",
          "properties": {
            "credentialsSecretRef": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "ldap": {
          "type": "object",
          "properties": {
            "url": {
              "type": "string"
            },
            "authenticationStrategy": {
              "type": "string",
              "enum": [
                "SIMPLE",
                "LDAPS",
                "START_TLS"
              ]
            },
            "managerDN": {
              "type": "string"
            },
            "managerPasswordSecretRef": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "key": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            },
            "userSearchBase": {
              "type": "string"
            },
            "userSearchFilter": {
              "type": "string"
            },
            "identityStrategy": {
              "type": "string",
              "enum": [
                "USE_DN",
                "USE_USERNAME"
              ]
            },
            "caSecretRef": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "key": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "oidc": {
          "type": "object",
          "properties": {
            "discoveryURL": {
              "type": "string"
            },
            "clientID": {
              "type": "string"
            },
            "clientSecretRef": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "key": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            },
            "claim": {
              "type": "string"
            },
            "additionalScopes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "caSecretRef": {
              "type": "object",
              "properties": {
                "name": {
                  "type": "string"
                },
                "key": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "definitions": {
    "intOrStringOrNull": {
      "anyOf": [
        {
          "type": "integer",
          "minimum": 0
        },
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "null"
        }
      ]
    }
  }
}
