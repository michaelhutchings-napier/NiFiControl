{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["image", "replicas", "service", "storage", "resources", "jvm", "deletionPolicy"],
  "properties": {
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "image": {
      "type": "object",
      "required": ["repository", "tag", "pullPolicy"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string", "minLength": 1 },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "replicas": { "type": "integer", "minimum": 1 },
    "service": {
      "type": "object",
      "required": ["type", "port"],
      "properties": {
        "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "nodePort": { "type": "integer", "minimum": 0, "maximum": 65535 },
        "annotations": { "type": "object" }
      }
    },
    "storage": {
      "type": "object",
      "required": ["enabled", "size", "accessModes"],
      "properties": {
        "enabled": { "type": "boolean" },
        "size": { "type": "string", "minLength": 1 },
        "storageClassName": { "type": "string" },
        "accessModes": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    },
    "resources": { "type": "object" },
    "jvm": {
      "type": "object",
      "required": ["heapInitial", "heapMax"],
      "properties": {
        "heapInitial": { "type": "string", "minLength": 1 },
        "heapMax": { "type": "string", "minLength": 1 }
      }
    },
    "coordination": {
      "type": "object",
      "properties": {
        "zookeeperConnectString": { "type": "string" },
        "zookeeperRootNode": { "type": "string" },
        "electionMaxWait": { "type": "string" }
      }
    },
    "api": {
      "type": "object",
      "properties": {
        "uri": { "type": "string" },
        "timeout": { "type": "string" }
      }
    },
    "additionalEnv": { "type": "array", "items": { "type": "object" } },
    "deletionPolicy": { "type": "string", "enum": ["Delete", "Orphan"] },
    "driftPolicy": {
      "type": "object",
      "properties": {
        "mode": { "type": "string", "enum": ["Ignore", "Warn", "Reconcile", "Fail"] }
      }
    }
  }
}
